vlarem-klasse:k1 a skos:Concept;
    skos:altLabel "VLAREM klasse 1"@nl;
    skos:definition "Indelingsklasse voor inrichtingen met de grootste milieu-impact. Voor deze activiteiten geldt een omgevingsvergunning klasse 1 (zwaarste procedure)."@nl;
    skos:inScheme conceptscheme-alg:vlarem-klasse;
    skos:note "Indelingsklasse voor inrichtingen met de grootste milieu-impact. Voor deze activiteiten geldt een omgevingsvergunning klasse 1 (zwaarste procedure)."@nl;
    skos:prefLabel "Klasse 1"@nl;
    skos:topConceptOf conceptscheme-alg:vlarem-klasse.
vlarem-klasse:k2 a skos:Concept;
    skos:altLabel "VLAREM klasse 2"@nl;
    skos:definition "Indelingsklasse voor inrichtingen met een middelgrote milieu-impact. Voor deze activiteiten geldt een omgevingsvergunning klasse 2."@nl;
    skos:inScheme conceptscheme-alg:vlarem-klasse;
    skos:note "Indelingsklasse voor inrichtingen met een middelgrote milieu-impact. Voor deze activiteiten geldt een omgevingsvergunning klasse 2."@nl;
    skos:prefLabel "Klasse 2"@nl;
    skos:topConceptOf conceptscheme-alg:vlarem-klasse.
vlarem-klasse:k3 a skos:Concept;
    skos:altLabel "VLAREM klasse 3"@nl;
    skos:definition "Indelingsklasse voor inrichtingen met een beperkte milieu-impact. Voor deze activiteiten geldt een meldingsplicht (klasse 3)."@nl;
    skos:inScheme conceptscheme-alg:vlarem-klasse;
    skos:note "Indelingsklasse voor inrichtingen met een beperkte milieu-impact. Voor deze activiteiten geldt een meldingsplicht (klasse 3)."@nl;
    skos:prefLabel "Klasse 3"@nl;
    skos:topConceptOf conceptscheme-alg:vlarem-klasse.
conceptscheme:datatypes a skos:ConceptScheme;
